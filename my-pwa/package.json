{
  "name": "my-pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --debug",
    "config:update": "node update-config.js",
    "preview": "vite preview --host 0.0.0.0",
    "sync": "npm run config:update && npx cap sync android",
    "serve-poc": "npx serve -s dist -l 5173",
    "build": "vite build",
    "build-app": "npm run build && npm run sync",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "mitt": "^3.0.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "dotenv": "^17.4.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
